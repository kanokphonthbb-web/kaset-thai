# โดเมนจริงของเว็บ (มีผลกับ metadata, sitemap.xml, robots.txt)
NEXT_PUBLIC_SITE_URL=https://kaset-thai.example.com
DATABASE_URL="file:./dev.db"
# ระบบหลังบ้าน /admin (ตั้งค่าเพื่อเปิดล็อกอิน — ถ้าเว้นว่าง = เข้าได้เลย dev)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=your-strong-password
AUTH_SECRET=random-long-secret
# Production DB (Turso/libSQL) — ถ้าตั้งค่า จะใช้แทน SQLite ไฟล์
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# อัปโหลดรูปในหลังบ้าน (production) — สร้าง Blob store ใน Vercel แล้วค่านี้จะถูกตั้งให้อัตโนมัติ
# ถ้าไม่ตั้ง = เก็บลง /public/uploads (ใช้ตอน dev เท่านั้น)
BLOB_READ_WRITE_TOKEN=
# Analytics (ถ้าต้องการ)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
